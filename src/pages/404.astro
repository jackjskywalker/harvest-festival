---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandMark from '../components/BrandMark.astro';
import { u } from '../utils/url';
---
<BaseLayout title="Page not found - Harvest Festival" description="That page wandered off. Head back to the Harvest Festival home.">
  <section class="nf">
    <div class="container-narrow nf-inner">
      <BrandMark name="harvey-running" decorative class="nf-horse" />
      <p class="eyebrow">404</p>
      <h1 class="display nf-title">This one got away.</h1>
      <p class="lede">The page you're looking for has wandered off the field. Let's get you back.</p>
      <div class="nf-actions">
        <a href={u('/')} class="btn btn--primary">Back to Home</a>
        <a href={u('/lineup')} class="btn btn--ghost">See the Lineup</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf { padding-block: var(--space-3xl); background: var(--hf-cream); }
  .nf-inner { display: grid; gap: var(--space-m); justify-items: center; text-align: center; }
  .nf-inner :global(.nf-horse) { width: min(320px, 70%); color: var(--hf-tomato); }
  .nf-title { font-size: var(--step-5); color: var(--hf-rust); }
  .nf-actions { display: flex; flex-wrap: wrap; gap: var(--space-s); justify-content: center; margin-top: var(--space-s); }
</style>
