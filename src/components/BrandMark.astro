---
/*
  BrandMark - inlines a real brand asset extracted from the official .ai file.
  SVGs live in src/assets/brand/ and use `currentColor`, so they inherit the
  CSS `color` of their context (set via the `tone` / class color).

  name: file basename in src/assets/brand (without .svg)
    wordmark-horizontal | wordmark-stacked | hf-monogram | hf-oval | hf-stars
    hf-script | hf-script-ring | cross-of-stars | harvey-running | harvey-rearing
*/
interface Props {
  name: string;
  title?: string;          // accessible label; omit for decorative marks
  decorative?: boolean;    // true → aria-hidden
  class?: string;
}
const { name, title, decorative = false, class: className = '' } = Astro.props;

// Eagerly import every brand SVG as a raw string for inlining.
const marks = import.meta.glob<string>('../assets/brand/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const key = `../assets/brand/${name}.svg`;
let svg = marks[key];
if (!svg) {
  throw new Error(`BrandMark: unknown asset "${name}". Available: ${Object.keys(marks).join(', ')}`);
}

// Strip the inline fixed sizing if any slipped through; make responsive + a11y.
svg = svg.replace(/<svg /, () => {
  const role = decorative ? 'role="presentation" aria-hidden="true"' : `role="img" aria-label="${title ?? name}"`;
  return `<svg class="brandmark ${className}" ${role} preserveAspectRatio="xMidYMid meet" `;
});
---
<Fragment set:html={svg} />

<style is:global>
  .brandmark { width: 100%; height: auto; display: block; }
</style>
