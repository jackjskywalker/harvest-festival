---
/* Phase 2 placeholder. Keeps nav/footer links live (no 404s) while clearly
   signalling the page is on the way. Replace with the real page in Phase 2. */
import BrandMark from './BrandMark.astro';
interface Props { eyebrow: string; phaseNote?: string; }
const { eyebrow, phaseNote = 'This page is coming soon.' } = Astro.props;
---
<section class="coming">
  <div class="container-narrow coming-inner">
    <BrandMark name="hf-stars" decorative class="coming-mark" />
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="display coming-title"><slot /></h1>
    <p class="coming-note">{phaseNote}</p>
    <div class="coming-actions">
      <a href="/" class="btn btn--primary">Back to Home</a>
      <a href="/tickets" class="btn btn--ghost">Get Tickets</a>
    </div>
  </div>
</section>

<style>
  .coming { padding-block: var(--space-3xl); background: var(--hf-cream); }
  .coming-inner { display: grid; gap: var(--space-m); justify-items: center; text-align: center; }
  .coming-inner :global(.coming-mark) { width: 96px; color: var(--hf-tomato); }
  .coming-title { font-size: var(--step-5); color: var(--hf-rust); }
  .coming-note { font-size: var(--step-1); color: var(--hf-moss); }
  .coming-actions { display: flex; flex-wrap: wrap; gap: var(--space-s); justify-content: center; margin-top: var(--space-s); }
</style>
